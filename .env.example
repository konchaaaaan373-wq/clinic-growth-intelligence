# =========================================================
# Clinic Growth Intelligence - 環境変数サンプル
# =========================================================
# このファイルを .env にコピーして利用します。
#   cp .env.example .env
#
# 重要: PAGESPEED_API_KEY / YOUTUBE_API_KEY は
#       Netlify Functions（サーバーサイド）でのみ使用します。
#       絶対にクライアント（VITE_ 接頭辞）に置かないでください。
# ---------------------------------------------------------

# PageSpeed Insights API キー（任意）。
# 未設定でも診断は動作します（pagespeed.status = "skipped"）。
PAGESPEED_API_KEY=

# YouTube Data API v3 キー（任意）。
# 未設定でも診断は動作します（youtube.status = "skipped"）。
YOUTUBE_API_KEY=

# --- クライアント側で参照する公開設定（VITE_ 接頭辞） ---
# これらはビルド時にバンドルへ埋め込まれます。秘密情報は入れないこと。
VITE_APP_NAME=Clinic Growth Intelligence
VITE_CONTACT_EMAIL=example@example.com
